# PostgreSQL (Docker Compose)
POSTGRES_USER=novelty
POSTGRES_PASSWORD=novelty_dev
POSTGRES_DB=novelty_precheck
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql://novelty:novelty_dev@localhost:5432/novelty_precheck?schema=public
PORT=3000
UPLOAD_DIR=./data/uploads

# Pipeline limits
MAX_PAGES=15
MAX_TOKENS=8000
SIM_THRESHOLD_RELATED=0.60
SIM_THRESHOLD_SIGNIFICANT=0.80
TOP_K_PER_QUERY=10
TOP_MATCHES_PER_CLAIM=5

# External APIs (set in local .env — never commit)
LLM_API_KEY=
LLM_MODEL=
EMBEDDING_MODEL=
SERPAPI_KEY=

# Frontend dev proxy target
API_URL=http://localhost:3000
