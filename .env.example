# PostgreSQL (Docker Compose)
POSTGRES_USER=novelty
POSTGRES_PASSWORD=novelty_dev
POSTGRES_DB=novelty_precheck
POSTGRES_PORT=5433

# Backend - required for app boot
DATABASE_URL=postgresql://novelty:novelty_dev@localhost:5433/novelty_precheck?schema=public
PORT=3000
UPLOAD_DIR=./data/uploads

# Pipeline limits
MAX_PAGES=15
MAX_TOKENS=8000
SIM_THRESHOLD_RELATED=0.60
SIM_THRESHOLD_SIGNIFICANT=0.80
TOP_K_PER_QUERY=10
TOP_MATCHES_PER_CLAIM=5
ARXIV_RETRY_COUNT=1

# External APIs (optional until pipeline stages are implemented)
LLM_API_KEY=
LLM_MODEL=
EMBEDDING_MODEL=
SERPAPI_KEY=

# Frontend dev proxy target
API_URL=http://localhost:3000
